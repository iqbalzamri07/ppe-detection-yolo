# PPE Detection System Configuration

# Detection Settings
CONFIDENCE=0.5

# Database Configuration
DATABASE_URL=sqlite:///./ppe_detection.db

# Email Notification Settings
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# Webhook Notification Settings
WEBHOOK_ENABLED=false
WEBHOOK_URL=https://your-webhook-url.com/alert
WEBHOOK_TIMEOUT=10

# Environment
ENVIRONMENT=development

# Notification Recipients (comma-separated)
ALERT_EMAILS=admin@company.com,safety@company.com
SUMMARY_EMAILS=admin@company.com